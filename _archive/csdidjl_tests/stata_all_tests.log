. * ═══════════════════════════════════════════════════════════════
. *  ARTEFACTO 1 — Stata csdid_jl results for ALL 12 scenarios
. *  Uses: csdid_jl wrapper (CSDid.jl via Julia plugin)
. *  Dataset: mpdta (500 counties × 5 years)
. *  Output: stata_results.csv, stata_aggte_results_full.csv
. * ═══════════════════════════════════════════════════════════════
. 
. set more off

. clear all

. 
. di "Stata version: `c(stata_version)'"
Stata version: 17

. di "Mode: `c(mode)'"
Mode: batch

. di ""


. 
. * ── Setup adopath ──────────────────────────────────────────────
. adopath + "C:\Users\Usuario\CSDid.jl"
  [1]  (BASE)      "C:\Program Files\Stata17\ado\base/"
  [2]  (SITE)      "C:\Program Files\Stata17\ado\site/"
  [3]              "."
  [4]  (PERSONAL)  "C:\Users\Usuario\ado\personal/"
  [5]  (PLUS)      "c:\ado\plus/"
  [6]  (OLDPLACE)  "c:\ado/"
  [7]              "C:\Users\Usuario\CSDid.jl"

. 
. * ── Load data ──────────────────────────────────────────────────
. import delimited "C:\Users\Usuario\CSDid.jl\data\mpdta.csv", clear
(encoding automatically selected: ISO-8859-1)
(6 vars, 2,500 obs)

. * Stata strips dots from variable names: first.treat → firsttreat
. * csdid_jl expects the gname var; rename for consistency with Julia
. cap rename firsttreat first_treat

. di "Dataset: mpdta"
Dataset: mpdta

. di "  Observations: `=_N'"
  Observations: 2500

. di "  Units: `=r(r)'"
  Units: .

. qui tab countyreal

. di "  Units: `=r(r)'"
  Units: 500

. qui tab year

. di "  Periods: `=r(r)'"
  Periods: 5

. di ""


. 
. * ── Open postfiles ─────────────────────────────────────────────
. tempname att_h agg_h

. tempfile att_f agg_f

. postfile `att_h' str20 scenario double(group t att se) using `att_f', replace
(file C:\Users\Usuario\AppData\Local\Temp\ST_12e4_000001.tmp not found)

. postfile `agg_h' str20(scenario agg_type) double(egt att_egt se_egt overall_a
> tt overall_se) using `agg_f', replace
(file C:\Users\Usuario\AppData\Local\Temp\ST_12e4_000002.tmp not found)

. 
. * ── Define scenario components ─────────────────────────────────
. local methods    dr ipw reg

. local cgroups    nevertreated notyettreated

. local cgshort_nevertreated  nev

. local cgshort_notyettreated nyt

. 
. * ═══════════════════════════════════════════════════════════════
. *  LOOP OVER ALL 12 SCENARIOS
. * ═══════════════════════════════════════════════════════════════
. foreach em of local methods {
  2.   foreach cg of local cgroups {
  3.     local cgs = "`cgshort_`cg''"
  4.     foreach covtype in nocov cov {
  5. 
.       local scname "`em'_`cgs'_`covtype'"
  6. 
.       if "`covtype'" == "cov" {
  7.         local covars "lpop"
  8.       }
  9.       else {
 10.         local covars ""
 11.       }
 12. 
.       di ""
 13.       di as txt "{hline 70}"
 14.       di as txt "=== SCENARIO: `scname' ==="
 15.       if "`covtype'" == "cov" {
 16.         di as txt "    `=upper("`em'")' | `cg' | xformla=~lpop"
 17.       }
 18.       else {
 19.         di as txt "    `=upper("`em'")' | `cg' | no covariates"
 20.       }
 21.       di as txt "{hline 70}"
 22. 
.       cap {
 23.         * Run csdid_jl
.         csdid_jl lemp `covars', tname(year) gname(first_treat) ///
>           idname(countyreal) est_method(`em') control_group(`cg')
 24. 
.         * ── Extract ATT(g,t) results ──
.         local ngt = e(ngt)
 25.         tempname att_m se_m grp_m tt_m
 26.         matrix `att_m' = e(att)
 27.         matrix `se_m'  = e(se)
 28.         matrix `grp_m' = e(group)
 29.         matrix `tt_m'  = e(t)
 30. 
.         forvalues i = 1/`ngt' {
 31.           local g = `grp_m'[1, `i']
 32.           local t = `tt_m'[1, `i']
 33.           local a = `att_m'[1, `i']
 34.           local s = `se_m'[1, `i']
 35.           post `att_h' ("`scname'") (`g') (`t') (`a') (`s')
 36.           di as txt "  ATT(g=`=string(`g',"%9.0f")', t=`=string(`t',"%9.0f
> ")') = " ///
>             as res %20.15f `a' as txt "  SE = " as res %20.15f `s'
 37.         }
 38. 
.         * ── Run aggregations via Julia ──
.         foreach atype in simple dynamic group calendar {
 39.           cap noisily {
 40.             _jl: _csdid_agg = CSDid.aggte(_csdid_r; type="`atype'")
 41.             _jl: st_numscalar("__ov_att", _csdid_agg.overall_att)
 42.             _jl: st_numscalar("__ov_se",  _csdid_agg.overall_se)
 43.             _jl: st_numscalar("__nagg",   Float64(length(_csdid_agg.egt)))
 44. 
.             local ov_att = scalar(__ov_att)
 45.             local ov_se  = scalar(__ov_se)
 46. 
.             * Post overall row
.             post `agg_h' ("`scname'") ("`atype'") (.) (.) (.) (`ov_att') (`ov
> _se')
 47.             di as txt "  aggte(`atype'): overall_att = " ///
>               as res %20.15f `ov_att' as txt "  SE = " as res %20.15f `ov_se'
 48. 
.             * Post detail rows (if any)
.             local nagg = scalar(__nagg)
 49.             if `nagg' > 0 {
 50.               _jl: _csdid_agg_egt_v = reshape(_csdid_agg.egt,     1, :)
 51.               _jl: _csdid_agg_att_v = reshape(_csdid_agg.att_egt,  1, :)
 52.               _jl: _csdid_agg_se_v  = reshape(_csdid_agg.se_egt,   1, :)
 53.               jl GetMatFromMat __agg_egt, source(_csdid_agg_egt_v)
 54.               jl GetMatFromMat __agg_att, source(_csdid_agg_att_v)
 55.               jl GetMatFromMat __agg_se,  source(_csdid_agg_se_v)
 56. 
.               forvalues j = 1/`nagg' {
 57.                 local e_j = __agg_egt[1, `j']
 58.                 local a_j = __agg_att[1, `j']
 59.                 local s_j = __agg_se[1, `j']
 60.                 post `agg_h' ("`scname'") ("`atype'") (`e_j') (`a_j') (`s_
> j') (`ov_att') (`ov_se')
 61.               }
 62.               cap matrix drop __agg_egt __agg_att __agg_se
 63.             }
 64.             cap scalar drop __ov_att __ov_se __nagg
 65.           }
 66.           if _rc {
 67.             di as txt "  aggte(`atype'): ERROR (rc=" _rc ")"
 68.           }
 69.         }
 70.       }
 71.       if _rc {
 72.         di as err "  SCENARIO FAILED (rc=" _rc ")"
 73.       }
 74.     }
 75.   }
 76. }

