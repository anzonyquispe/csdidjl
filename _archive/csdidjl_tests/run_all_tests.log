. * ═══════════════════════════════════════════════════════════════
. *  BLOCK 6: sim parity (24 scenarios)
. *  6 datasets × 2 control groups × 2 estimators
. * ═══════════════════════════════════════════════════════════════
. 
. local sim_datasets  tp2_const tp4_const tp4_dyn tp5_dyn tp8_dyn tp10_const

. local sim_controls  nevertreated notyettreated

. local sim_ests      dr reg

. 
. foreach ds of local sim_datasets {
  2.   * Use local + forward slash to avoid Stata \` escaping issue
.   import delimited "`dpath'/`ds'.csv", clear
  3.   di ""
  4.   di "Dataset: `ds'  N=`=_N'"
  5. 
.   foreach cg of local sim_controls {
  6.     foreach em of local sim_ests {
  7.       local scname "sim_`ds'_`cg'_`em'"
  8. 
.       di ""
  9.       di as txt "{hline 70}"
 10.       di as txt "=== SCENARIO: `scname' ==="
 11.       di as txt "{hline 70}"
 12. 
.       cap noisily {
 13.         csdid_jl y x, tname(period) gname(g) idname(id) ///
>           est_method(`em') control_group(`cg')
 14. 
.         local ngt = e(ngt)
 15.         tempname att_m se_m grp_m tt_m
 16.         matrix `att_m' = e(att)
 17.         matrix `se_m'  = e(se)
 18.         matrix `grp_m' = e(group)
 19.         matrix `tt_m'  = e(t)
 20. 
.         forvalues i = 1/`ngt' {
 21.           local g = `grp_m'[1, `i']
 22.           local t = `tt_m'[1, `i']
 23.           local a = `att_m'[1, `i']
 24.           local s = `se_m'[1, `i']
 25.           post `att_h' ("`scname'") (`g') (`t') (`a') (`s')
 26.         }
 27.         di as txt "  Posted `ngt' ATT(g,t) rows"
 28.       }
 29.       if _rc {
 30.         di as err "  SCENARIO FAILED (rc=" _rc ")"
 31.       }
 32.     }
 33.   }
 34. }
