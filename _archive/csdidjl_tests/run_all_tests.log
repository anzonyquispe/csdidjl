. 
. * ═══════════════════════════════════════════════════════════════
. *  BLOCK 1: mpdta 12-scenario grid (3 methods × 2 cg × 2 cov)
. * ═══════════════════════════════════════════════════════════════
. 
. import delimited "`dpath'/mpdta.csv", clear
(encoding automatically selected: ISO-8859-1)
(6 vars, 2,500 obs)

. cap rename firsttreat first_treat

. di "Dataset: mpdta  N=`=_N'"
Dataset: mpdta  N=2500

. 
. local methods    dr ipw reg

. local cgroups    nevertreated notyettreated

. local cgshort_nevertreated  nev

. local cgshort_notyettreated nyt

. 
. foreach em of local methods {
  2.   foreach cg of local cgroups {
  3.     local cgs = "`cgshort_`cg''"
  4.     foreach covtype in nocov cov {
  5.       local scname "`em'_`cgs'_`covtype'"
  6. 
.       if "`covtype'" == "cov" {
  7.         local covars "lpop"
  8.       }
  9.       else {
 10.         local covars ""
 11.       }
 12. 
.       di ""
 13.       di as txt "{hline 70}"
 14.       di as txt "=== SCENARIO: `scname' ==="
 15.       di as txt "{hline 70}"
 16. 
.       cap noisily {
 17.         csdid_jl lemp `covars', tname(year) gname(first_treat) ///
>           idname(countyreal) est_method(`em') control_group(`cg')
 18. 
.         * ── Extract ATT(g,t) results ──
.         local ngt = e(ngt)
 19.         tempname att_m se_m grp_m tt_m
 20.         matrix `att_m' = e(att)
 21.         matrix `se_m'  = e(se)
 22.         matrix `grp_m' = e(group)
 23.         matrix `tt_m'  = e(t)
 24. 
.         forvalues i = 1/`ngt' {
 25.           local g = `grp_m'[1, `i']
 26.           local t = `tt_m'[1, `i']
 27.           local a = `att_m'[1, `i']
 28.           local s = `se_m'[1, `i']
 29.           post `att_h' ("`scname'") (`g') (`t') (`a') (`s')
 30.         }
 31.         di as txt "  Posted `ngt' ATT(g,t) rows"
 32. 
.         * ── Run aggregations via Julia ──
.         foreach atype in simple dynamic group calendar {
 33.           cap noisily {
 34.             _jl: _csdid_agg = CSDid.aggte(_csdid_r; type="`atype'")
 35.             _jl: st_numscalar("__ov_att", _csdid_agg.overall_att)
 36.             _jl: st_numscalar("__ov_se",  _csdid_agg.overall_se)
 37.             _jl: st_numscalar("__nagg",   Float64(length(_csdid_agg.egt)))
 38. 
.             local ov_att = scalar(__ov_att)
 39.             local ov_se  = scalar(__ov_se)
 40. 
.             post `agg_h' ("`scname'") ("`atype'") (.) (.) (.) (`ov_att') (`ov
> _se')
 41. 
.             local nagg = scalar(__nagg)
 42.             if `nagg' > 0 {
 43.               _jl: _csdid_agg_egt_v = reshape(_csdid_agg.egt,     1, :)
 44.               _jl: _csdid_agg_att_v = reshape(_csdid_agg.att_egt,  1, :)
 45.               _jl: _csdid_agg_se_v  = reshape(_csdid_agg.se_egt,   1, :)
 46.               jl GetMatFromMat __agg_egt, source(_csdid_agg_egt_v)
 47.               jl GetMatFromMat __agg_att, source(_csdid_agg_att_v)
 48.               jl GetMatFromMat __agg_se,  source(_csdid_agg_se_v)
 49. 
.               forvalues j = 1/`nagg' {
 50.                 local e_j = __agg_egt[1, `j']
 51.                 local a_j = __agg_att[1, `j']
 52.                 local s_j = __agg_se[1, `j']
 53.                 post `agg_h' ("`scname'") ("`atype'") (`e_j') (`a_j') (`s_
> j') (`ov_att') (`ov_se')
 54.               }
 55.               cap matrix drop __agg_egt __agg_att __agg_se
 56.             }
 57.             cap scalar drop __ov_att __ov_se __nagg
 58.           }
 59.           if _rc {
 60.             di as txt "  aggte(`atype'): ERROR (rc=" _rc ")"
 61.           }
 62.         }
 63.       }
 64.       if _rc {
 65.         di as err "  SCENARIO FAILED (rc=" _rc ")"
 66.       }
 67.     }
 68.   }
 69. }

